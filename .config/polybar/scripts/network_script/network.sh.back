#!/bin/env bash

# Detectar interfaz activa
active=$(ip route | grep default | awk '{print $5}')

if [[ "$active" == "wlo1" ]]; then
    essid=$(iwgetid -r)
    echo "蟀柀 $essid"
elif [[ "$active" == "enp2s0" ]]; then
    ip=$(ip -4 addr show enp2s0 | grep -oP '(?<=inet\s)\d+(\.\d+){3}')
    echo "蟀垁 $ip"
else
    echo "蟀柂"
fi
